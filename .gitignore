# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib
/target/*

# Archives
/*.tar*

# Test binary, build with `go test -c`
*.test

# Test-related patterns
/*.log
/test-logs/

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Project-local glide cache, RE: https://github.com/Masterminds/glide/issues/736
.glide/

# Custom ignores
.DS_Store
*.swp
.env

# Secrets: never commit private keys or certificate material. Example/test
# certificates should be generated at apply/test time (see the tls provider in
# examples and the certificate fixtures in the acceptance tests) rather than
# checked in. Add a genuinely-public example cert with `git add -f` if needed.
*.pem
*.key
*.p12
*.pfx

# IDE
.idea/

/assets/terraform/examples/**/provider.tf
/assets/terraform/examples/provider.tf.template

# Local semantic-release configuration if you create one for testing
release.config.local.js
release.config.local.json
.releaserc.local.js
.releaserc.local.json
.releaserc.local.yaml
.releaserc.local.yml

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
.npm

# Emacs
*~
\#*\#
.\#*


# Makefile-related patterns
/Makefile.local
/*-stamp
/panos-creds.txt
/config.yaml
/generated
