// New is a helper function to get the provider implementation.
// wg: WaitGroup for coordinating graceful shutdown with background writers
// shutdownChan: Channel for signaling shutdown to background writers
func New(version string, wg *sync.WaitGroup, shutdownChan chan struct{}) func() provider.Provider {
	return func() provider.Provider {
		return &PanosProvider{
			version:      version,
			wg:           wg,
			shutdownChan: shutdownChan,
		}
	}
}

