type ProviderData struct {
	Client         pangoutil.PangoClient
	BatchingConfig sdkmanager.BatchingConfig
	CacheEnabled   bool
	WriteMode      XmlWriteMode // Write mode for runtime conditional calls

	// Per-resource-type cache storage
	// Key: resource type name (e.g., "address", "service")
	// Value: CacheManager instance
	caches sync.Map
}

// GetOrCreateCache returns the cache for a given resource type, creating if needed.
// The marshaller is only used when creating a new cache.
// This is a package-level function because Go methods cannot have type parameters.
func GetOrCreateCache[E sdkmanager.Entry, M sdkmanager.Marshaller[E]](
	providerData *ProviderData,
	resourceType string,
	marshaller M,
	resourceCacheEnabled bool,
) sdkmanager.CacheManager[E] {
	// Try to load existing cache
	if cached, ok := providerData.caches.Load(resourceType); ok {
		return cached.(sdkmanager.CacheManager[E])
	}

	// Create new cache based on both provider AND resource config
	// Both must be enabled for caching to work
	var cache sdkmanager.CacheManager[E]
	if providerData.CacheEnabled && resourceCacheEnabled {
		cache = sdkmanager.NewEnabledCacheManager(marshaller)
	} else {
		cache = sdkmanager.NewNoOpCacheManager[E]()
	}

	// Store and return (LoadOrStore handles race conditions)
	actual, _ := providerData.caches.LoadOrStore(resourceType, cache)
	return actual.(sdkmanager.CacheManager[E])
}

// Configure prepares the provider.
func (p *PanosProvider) Configure(ctx context.Context, req provider.ConfigureRequest, resp *provider.ConfigureResponse) {
	tflog.Info(ctx, "Configuring the provider client...")

	var config PanosProviderModel
	resp.Diagnostics.Append(req.Config.Get(ctx, &config)...)
	if resp.Diagnostics.HasError() {
		return
	}

	// Validate mutual exclusivity between local XML mode and API mode
	// This validation runs AFTER environment variable resolution
	hasXmlFilePath := config.XmlFilePath.ValueStringPointer() != nil && config.XmlFilePath.ValueString() != ""
	hasConfigFile := config.ConfigFile.ValueStringPointer() != nil && config.ConfigFile.ValueString() != ""
	hasApiConfig := (config.Hostname.ValueString() != "" && config.ApiKey.ValueString() != "") ||
		(config.Hostname.ValueString() != "" && config.Username.ValueString() != "" && config.Password.ValueString() != "")

	if hasXmlFilePath && hasApiConfig {
		resp.Diagnostics.AddError(
			"Invalid provider configuration",
			"Cannot configure both xml_file_path and API mode (hostname + api_key). These modes are mutually exclusive. "+
				"Use xml_file_path for local XML mode OR use hostname + api_key for API mode.",
		)
		return
	}

	if hasXmlFilePath && hasConfigFile {
		resp.Diagnostics.AddError(
			"Invalid provider configuration",
			"Cannot configure both xml_file_path and config_file. These are different modes for working with local files. "+
				"Use xml_file_path for read/write local XML mode OR use config_file for read-only local inspection mode.",
		)
		return
	}

	if !hasXmlFilePath && !hasConfigFile && !hasApiConfig {
		resp.Diagnostics.AddError(
			"Invalid provider configuration",
			"Must configure either xml_file_path (for local XML mode) OR hostname + api_key (for API mode) OR config_file (for local inspection mode). "+
				"No valid provider configuration was found.",
		)
		return
	}

	var con pangoutil.PangoClient
	var xmlWriteMode XmlWriteMode = WriteModeSafe // Default write mode

	if hasXmlFilePath {
		tflog.Info(ctx, "Configuring client for local XML mode")

		// Parse write mode configuration
		writerConfig := WriterConfig{
			Mode:             WriteModeSafe, // default
			CheckIntervalMs:  10,            // default for deferred mode
			FlushIntervalSec: 30,            // default for periodic mode
		}

		if !config.XmlWriteMode.IsNull() {
			writerConfig.Mode = XmlWriteMode(config.XmlWriteMode.ValueString())
		}

		if !config.XmlWriteCheckIntervalMs.IsNull() {
			writerConfig.CheckIntervalMs = int(config.XmlWriteCheckIntervalMs.ValueInt64())
		}

		if !config.XmlWriteFlushIntervalSec.IsNull() {
			writerConfig.FlushIntervalSec = int(config.XmlWriteFlushIntervalSec.ValueInt64())
		}

		// Store write mode for ProviderData
		xmlWriteMode = writerConfig.Mode

		// Configure LocalXmlClient auto-save based on write mode
		// Safe mode: auto-save enabled
		// Deferred/Periodic modes: auto-save disabled (DeferredWriter handles writes)
		autoSave := writerConfig.Mode == WriteModeSafe

		// Create LocalXmlClient with auto-save configuration
		localClient, err := sdk.NewLocalXmlClient(
			config.XmlFilePath.ValueString(),
			sdk.WithAutoSave(autoSave),
		)
		if err != nil {
			resp.Diagnostics.AddError(
				"Failed to create local XML client",
				fmt.Sprintf("Error creating client for file %q: %s\n\n"+
					"Please ensure the file path is correct and accessible. "+
					"For write operations, the directory must exist and be writable.",
					config.XmlFilePath.ValueString(), err.Error()),
			)
			return
		}

		// Setup/initialize the client (loads the XML file if it exists)
		// This is deferred from constructor to allow explicit control over file loading
		if err := localClient.Setup(); err != nil {
			resp.Diagnostics.AddError(
				"Failed to initialize local XML client",
				fmt.Sprintf("Error loading XML file %q: %s\n\n"+
					"If the file doesn't exist yet, it will be created on first write operation. "+
					"If the file exists, please ensure it contains valid PAN-OS XML configuration.",
					config.XmlFilePath.ValueString(), err.Error()),
			)
			return
		}

		// Assign LocalXmlClient directly - it implements PangoClient interface
		// Both LocalXmlClient and sdk.Client implement PangoClient, allowing resources to use them identically
		con = localClient

		// Initialize DeferredWriter singleton
		initDeferredWriter(writerConfig, localClient, p.wg, p.shutdownChan)

		tflog.Info(ctx, "Local XML mode client configured successfully", map[string]any{
			"file_path":  config.XmlFilePath.ValueString(),
			"auto_save":  autoSave,
			"write_mode": string(writerConfig.Mode),
		})
	} else if config.ConfigFile.ValueStringPointer() != nil {
		tflog.Info(ctx, "Configuring client for local inspection mode")
		con = &sdk.Client{}
		if err := con.SetupLocalInspection(config.ConfigFile.ValueString(), config.PanosVersion.ValueString()); err != nil {
			resp.Diagnostics.AddError("Error setting up local inspection mode", err.Error())
			return
		}
	} else {
		tflog.Info(ctx, "Configuring client for API mode")
		var logCategories sdk.LogCategory
		if !config.SdkLogCategories.IsNull() {
			categories := strings.Split(config.SdkLogCategories.ValueString(), ",")
			var err error
			logCategories, err = sdk.LogCategoryFromStrings(categories)
			if err != nil {
				resp.Diagnostics.AddError("Failed to configure Terraform provider", err.Error())
				return
			}
		}

		var logLevel slog.Level
		if !config.SdkLogLevel.IsNull() {
			levelStr := config.SdkLogLevel.ValueString()
			err := logLevel.UnmarshalText([]byte(levelStr))
			if err != nil {
				resp.Diagnostics.AddError("Failed to configure Terraform provider", fmt.Sprintf("Invalid Log Level: %s", levelStr))
			}
		} else {
			logLevel = slog.LevelInfo
		}

		con = &sdk.Client{
			Hostname:        config.Hostname.ValueString(),
			Username:        config.Username.ValueString(),
			Password:        config.Password.ValueString(),
			ApiKey:          config.ApiKey.ValueString(),
			Protocol:        config.Protocol.ValueString(),
			Port:            int(config.Port.ValueInt64()),
			Target:          config.Target.ValueString(),
			ApiKeyInRequest: config.ApiKeyInRequest.ValueBool(),
			// Headers from AdditionalHeaders
			SkipVerifyCertificate: config.SkipVerifyCertificate.ValueBool(),
			AuthFile:              config.AuthFile.ValueString(),
			CheckEnvironment:      true,
			Logging: sdk.LoggingInfo{
				LogLevel: logLevel,
				LogCategories: logCategories,
			},
			//Agent:            fmt.Sprintf("Terraform/%s Provider/scm Version/%s", req.TerraformVersion, p.version),
		}

		if err := con.Setup(); err != nil {
			resp.Diagnostics.AddError("Provider parameter value error", err.Error())
			return
		}

		//con.HttpClient.Transport = sdkapi.NewTransport(con.HttpClient.Transport, con)

		if err := con.Initialize(ctx); err != nil {
			resp.Diagnostics.AddError("Initialization error", err.Error())
			return
		}
	}

	batchSize := config.MultiConfigBatchSize.ValueInt64()
	if batchSize == 0 {
		batchSize = 500
	} else if batchSize < 0 || batchSize > 10000 {
		resp.Diagnostics.AddError("Failed to configure Terraform provider", fmt.Sprintf("multi_config_batch_size must be between 1 and 10000, value: %d", batchSize))
		return
	}

	// Parse experimental batching configuration
	readBatchSize := config.ExperimentalReadBatchSize.ValueInt64()
	if readBatchSize == 0 {
		readBatchSize = 50
	} else if readBatchSize < 1 || readBatchSize > 1000 {
		resp.Diagnostics.AddError("Failed to configure Terraform provider", fmt.Sprintf("experimental_read_batch_size must be between 1 and 1000, value: %d", readBatchSize))
		return
	}

	listStrategy := sdkmanager.StrategyEager
	if !config.ExperimentalListStrategy.IsNull() {
		strategyStr := config.ExperimentalListStrategy.ValueString()
		if strategyStr == "lazy" {
			listStrategy = sdkmanager.StrategyLazy
		} else if strategyStr != "eager" {
			resp.Diagnostics.AddError("Failed to configure Terraform provider", fmt.Sprintf("experimental_list_strategy must be 'eager' or 'lazy', value: %s", strategyStr))
			return
		}
	}

	shardingStrategy := sdkmanager.ShardingDisabled
	if !config.ExperimentalShardingStrategy.IsNull() {
		shardingStr := config.ExperimentalShardingStrategy.ValueString()
		if shardingStr == "enabled" {
			shardingStrategy = sdkmanager.ShardingEnabled
		} else if shardingStr != "disabled" {
			resp.Diagnostics.AddError("Failed to configure Terraform provider", fmt.Sprintf("experimental_sharding_strategy must be 'disabled' or 'enabled', value: %s", shardingStr))
			return
		}
	}

	// Parse experimental cache strategy
	cacheStrategy := sdkmanager.CacheStrategyDisabled
	if !config.ExperimentalCacheStrategy.IsNull() {
		cacheStr := config.ExperimentalCacheStrategy.ValueString()
		if cacheStr == "enabled" {
			cacheStrategy = sdkmanager.CacheStrategyEnabled
		} else if cacheStr != "disabled" {
			resp.Diagnostics.AddError("Failed to configure Terraform provider", fmt.Sprintf("experimental_cache_strategy must be 'disabled' or 'enabled', got: %s", cacheStr))
			return
		}
	}

	batchingConfig := sdkmanager.BatchingConfig{
		MultiConfigBatchSize: int(batchSize),
		ReadBatchSize:        int(readBatchSize),
		ListStrategy:         listStrategy,
		ShardingStrategy:     shardingStrategy,
		CacheStrategy:        cacheStrategy,
	}

	providerData := &ProviderData{
		Client:         con,
		BatchingConfig: batchingConfig,
		CacheEnabled:   cacheStrategy == sdkmanager.CacheStrategyEnabled,
		WriteMode:      xmlWriteMode, // Write mode from local XML configuration (safe mode for API mode)
	}

	resp.DataSourceData = providerData
	resp.ResourceData = providerData
	resp.EphemeralResourceData = providerData
	resp.ActionData = providerData

	// Done.
	tflog.Info(ctx, "Configured client", map[string]any{"success": true})
}

